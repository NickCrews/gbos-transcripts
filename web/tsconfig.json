{
  "compilerOptions": {
    "types": ["node"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true
  },
  "include": ["src", "drizzle.config.ts"]
}
